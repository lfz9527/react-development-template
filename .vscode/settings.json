{
  "files.eol": "\n",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "always",
    "source.fixAll.eslint": "always",
    "source.fixAll.prettier": "always",
    "source.fixAll.stylelint": "always"
  },
  "css.lint.unknownAtRules": "ignore",
  "cSpell.words": ["esbenp"]
}
